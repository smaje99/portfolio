---
interface Props {
  navigation: { label: string; href: string }[];
  languageSwitcherLabel: string;
  languageLabel: string;
  languageSwitcherHref: string;
  languageSwitcherLocale: 'es' | 'en';
  logoAlt: string;
}

const {
  navigation,
  languageSwitcherLabel,
  languageLabel,
  languageSwitcherHref,
  languageSwitcherLocale,
  logoAlt,
} = Astro.props;
---

<header class="header">
  <img
    src="/brand.svg"
    alt={logoAlt}
    width="48"
    height="48"
  />

  <nav class="nav">
    {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    <a
      class="language-switcher"
      href={languageSwitcherHref}
      aria-label={languageSwitcherLabel}
      rel="alternate"
      hreflang={languageSwitcherLocale}
    >
      {languageLabel}
    </a>
  </nav>
</header>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;

    padding: 1rem 4rem;

    & > img {
      width: 3rem;
      height: 3rem;
      filter: drop-shadow(0 0 1.25rem rgb(224 255 79 / 20%));
    }

    & > .nav {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;

      & > a {
        color: var(--muted-foreground);
        padding: 0.55rem 0.95rem;
        border-radius: 999px;
        border: 1px solid rgb(66 119 127 / 45%);
        background: rgb(11 43 49 / 56%);
        transition:
          color 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease,
          transform 180ms ease;
      }

      & > a:hover,
      & > a:focus-visible {
        color: var(--foreground);
        border-color: var(--brand-lime-soft);
        background: rgb(21 62 68 / 90%);
        transform: translateY(-1px);
      }

      & > .language-switcher {
        color: var(--foreground);
        border-color: rgb(224 255 79 / 38%);
        background: rgb(224 255 79 / 10%);
      }
    }
  }

  @media (width <= 720px) {
    .header {
      padding-inline: 1rem;
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
