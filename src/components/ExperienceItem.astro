---
import CalendarIcon from "../icons/CalendarIcon.astro";
import { type Experience } from "../types/experience";
import { formatDateToMonthYear } from '../utils/date';
import { capitalizeFirstLetter } from '../utils/string';

interface Props extends Experience {}

const {
  position,
  company,
  description,
  startDate,
  link,
  current,
  latest,
} = Astro.props;
---

<li class="experience-item">
  <span>
    <CalendarIcon />
  </span>
  <h3>
    {position}
    {current ? <span>Current</span> : null}
    {latest ? <span>Latest</span> : null}
    <span>{company}</span>
  </h3>
  <time datetime={startDate.toDateString()}>
    {capitalizeFirstLetter(formatDateToMonthYear(startDate))}
  </time>
  <p>{description}</p>
  {link ? <a href="#" /> : null}
</li>

<style>
  .experience-item {
    margin-inline-start: 1.5rem;
    margin-bottom: 2.5rem;

    & > span {
      position: absolute;
      inset-inline-start: -0.75rem;

      width: 1.5rem;
      height: 1.5rem;

      display: flex;
      justify-content: center;
      align-items: center;

      background-color: var(--primary);

      border-radius: calc(infinity * 1px);
      box-shadow:
        rgb(4 30 35) 0px 0px 0px 0px,
        rgb(4 30 35) 0px 0px 0px 8px,
        rgb(0 0 0 / 0) 0px 0px 0px 0px;

      & > svg {
        width: 0.625rem;
        height: 0.625rem;

        color: var(--primary-foreground);
      }
    }

    & > h3 {
      display: inline-flex;
      align-items: center;

      margin-bottom: 0.25rem;

      font-size: 1.125rem;
      line-height: 1.75rem;
      font-weight: 600;

      color: var(--foreground);

      & > span {
        font-size: 0.875rem;
        line-height: 1.25rem;

        margin-inline-start: 0.75rem;
        margin-inline-end: 0.5rem;
        padding: 0.125rem 0.625rem;

        border: 1px solid rgb(224 255 79 / 40%);
        border-radius: 999px;

        background-color: rgb(224 255 79 / 14%);
        color: var(--foreground);
      }
    }

    & > time {
      display: block;

      margin-bottom: 0.5rem;

      font-size: 0.875rem;
      line-height: 1;
      font-weight: 400;

      color: var(--muted-foreground);
    }

    & > p {
      margin-bottom: 1rem;

      font-size: 1rem;
      line-height: 1.5rem;
      font-weight: 400;

      color: var(--secondary-foreground);
    }
  }
</style>
