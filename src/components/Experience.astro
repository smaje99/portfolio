---
import ExperienceItem from "./ExperienceItem.astro";
import { type Experience } from '../types/experience';
import type { Locale } from '../i18n/site';

interface Props {
  readonly experiences: Experience[];
  readonly locale: Locale;
  readonly labels: {
    current: string;
    latest: string;
  };
}

const { experiences, locale, labels } = Astro.props;
---

<ol class="experience">
  {experiences.map((experience) => (
    <ExperienceItem {...experience} locale={locale} labels={labels} />
  ))}
</ol>

<style>
  .experience {
    position: relative;
    border-inline-start-width: 1px;
    border-color: rgb(66 119 127 / 60%);

    &:hover {
      border-color: var(--brand-lime-soft);
    }
  }
</style>
