---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';

import ExperienceContainer from '@/components/Experience.astro';
import HeroActions from '@/components/HeroActions';
import SocialPill from '@/components/SocialPill.astro';
import SectionContainer from '@/components/SectionContainer.astro';
import GitHubIcon from '@/icons/GitHubIcon.astro';
import LinkedInIcon from '@/icons/LinkedInIcon.astro';
import MailIcon from '@/icons/MailIcon.astro';
import {
  getAlternateLocale,
  getHomeCopy,
  localizeExperiences,
  locales,
  type Locale,
} from '@/i18n/site';
import Layout from '@/layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = getHomeCopy(locale);
const entries = await getCollection('experiences');
const experiences = localizeExperiences(entries, locale);
const alternateLocale = getAlternateLocale(locale);
const basePath = getRelativeLocaleUrl(locale, '');
const canonicalPath = basePath;
const alternatePath = getRelativeLocaleUrl(alternateLocale, '');
const navigation = copy.navigation.map((item) => ({
  label: item.label,
  href: `${basePath}${item.hash}`,
}));
const alternates = locales.map((localeCode) => ({
  hreflang: localeCode,
  href: getRelativeLocaleUrl(localeCode, ''),
}));
---

<Layout
  title={copy.title}
  description={copy.description}
  lang={locale}
  canonicalPath={canonicalPath}
  alternates={[
    ...alternates,
    { hreflang: 'x-default', href: getRelativeLocaleUrl('es', '') },
  ]}
  navigation={navigation}
  languageSwitcherLabel={copy.languageSwitcherLabel}
  languageLabel={copy.languageLabel}
  languageSwitcherHref={alternatePath}
  languageSwitcherLocale={alternateLocale}
  logoAlt={copy.logoAlt}
>
  <main id="top" class="portfolio-page">
    <SectionContainer>
      <section class="hero-panel" aria-labelledby="intro-title">
        <div class="hero-grid">
          <div class="hero-copy animate-in fade-in slide-in-from-bottom-4 duration-700">
            <h1 id="intro-title" aria-label={copy.hero.name} class="animate-in fade-in slide-in-from-bottom-3 duration-700">
              <span>{copy.hero.nameLines[0]}</span>
              <span>{copy.hero.nameLines[1]}</span>
            </h1>
            <p class="hero-role animate-in fade-in slide-in-from-bottom-2 duration-700 delay-100">{copy.hero.role}</p>
            <p class="hero-kicker animate-in fade-in slide-in-from-bottom-2 duration-700 delay-150">{copy.hero.specialties}</p>
            <p class="hero-summary animate-in fade-in slide-in-from-bottom-2 duration-700 delay-200">{copy.hero.summary}</p>

            <HeroActions
              projectsLabel={copy.heroActions.projects}
              resumeLabel={copy.heroActions.resume}
              contactLabel={copy.heroActions.contact}
            />
          </div>

          <aside
            class="hero-visual animate-in fade-in zoom-in-95 slide-in-from-right-4 duration-700 delay-150"
            aria-hidden="true"
          >
            <div class="hero-visual-shell">
              <div class="hero-visual-frame"></div>
              <div class="hero-orbit hero-orbit-large"></div>
              <div class="hero-orbit hero-orbit-small"></div>
              <div class="hero-grid-runes">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="hero-data-lines">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <img src="/brand.svg" alt="" width="261" height="278" class="hero-brand-mark" />
            </div>
          </aside>
        </div>

        <div id="contact" class="hero-contact-band animate-in fade-in slide-in-from-bottom-3 duration-700 delay-300">
          <div class="hero-contact-copy">
            <p class="hero-contact-label">{copy.contactSection.eyebrow}</p>
            <p class="hero-contact-title">{copy.contactSection.title}</p>
          </div>

          <div class="hero-contact-links" aria-label={copy.socials.contact}>
            <SocialPill href="http://linkedin.com/in/smaje">
              <LinkedInIcon />
              {copy.socials.linkedin}
            </SocialPill>
            <SocialPill href="https://github.com/smaje99">
              <GitHubIcon />
              {copy.socials.github}
            </SocialPill>
            <SocialPill href="mailto:smajefranco@gmail.com">
              <MailIcon />
              {copy.socials.contact}
            </SocialPill>
          </div>
        </div>
      </section>
    </SectionContainer>

    <SectionContainer>
      <section id="focus" class="content-panel" aria-labelledby="focus-title">
        <header class="panel-header">
          <p>01</p>
          <h2 id="focus-title">{copy.focusSection.title}</h2>
        </header>

        <ol class="focus-grid">
          {copy.focusSection.items.map((item, index) => (
            <li class="focus-item">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{item.title}</h3>
            </li>
          ))}
        </ol>
      </section>
    </SectionContainer>

    <SectionContainer>
      <section id="projects" class="content-panel" aria-labelledby="projects-title">
        <header class="panel-header">
          <p>02</p>
          <h2 id="projects-title">{copy.projectsSection.title}</h2>
        </header>

        <div class="projects-grid">
          {copy.projectsSection.items.map((project) => (
            <article class="project-card">
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </article>
          ))}
        </div>
      </section>
    </SectionContainer>

    <SectionContainer>
      <section id="experience" class="content-panel experience-panel" aria-labelledby="experience-title">
        <header class="panel-header">
          <p>03</p>
          <div class="panel-heading-copy">
            <h2 id="experience-title">{copy.experienceSection.title}</h2>
            <p>{copy.experienceSection.intro}</p>
          </div>
        </header>

        <ExperienceContainer
          experiences={experiences}
          locale={locale}
          labels={copy.experienceLabels}
        />
      </section>
    </SectionContainer>
  </main>
</Layout>

<style>
  .portfolio-page {
    width: min(1100px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 5rem;
    display: grid;
    gap: 1.5rem;
  }

  .hero-panel,
  .content-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(75 131 140 / 36%);
    border-radius: 2rem;
    background:
      linear-gradient(180deg, rgb(11 43 49 / 88%), rgb(7 34 40 / 94%));
    box-shadow:
      0 24px 80px rgb(0 0 0 / 28%),
      inset 0 1px 0 rgb(255 255 255 / 4%);
    backdrop-filter: blur(16px);
  }

  .hero-panel::before,
  .content-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgb(224 255 79 / 0%) 0%, rgb(224 255 79 / 6%) 46%, rgb(127 221 211 / 0%) 100%);
    opacity: 0.9;
  }

  .hero-panel {
    padding: 2rem;
    display: grid;
    gap: 1.5rem;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.5rem;
  }

  .hero-copy {
    position: relative;
    max-width: 42rem;
  }

  .hero-kicker,
  .hero-role {
    margin: 0;
    font-weight: 600;
  }

  .hero-kicker {
    margin-top: 0.9rem;
    color: color-mix(in srgb, var(--brand-aqua) 76%, var(--brand-mist-100) 24%);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-copy > h1 {
    margin: 0;
    max-width: 10ch;
    display: grid;
    gap: 0.1em;
    font-size: clamp(2.9rem, 6vw, 5.4rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
  }

  .hero-role {
    margin-top: 0.9rem;
    max-width: 22ch;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    color: var(--foreground);
    text-wrap: balance;
  }

  .hero-summary {
    max-width: 39rem;
    margin: 1.2rem 0 0;
    color: var(--secondary-foreground);
    font-size: 1.05rem;
    line-height: 1.78;
    text-wrap: pretty;
  }

  .hero-visual {
    position: relative;
    min-height: 21rem;
    border: 1px solid rgb(75 131 140 / 24%);
    border-radius: 1.75rem;
    background:
      radial-gradient(circle at 50% 50%, rgb(224 255 79 / 9%), transparent 0 10rem),
      linear-gradient(160deg, rgb(4 25 30 / 16%), rgb(4 25 30 / 48%));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 4%),
      inset 0 0 0 1px rgb(255 255 255 / 2%);
  }

  .hero-visual-shell {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .hero-visual-frame {
    position: absolute;
    inset: 1.35rem;
    border-radius: 1.5rem;
    border: 1px solid rgb(75 131 140 / 14%);
    background: linear-gradient(180deg, rgb(4 25 30 / 8%), rgb(4 25 30 / 0%));
  }

  .hero-brand-mark {
    position: relative;
    z-index: 2;
    width: min(10.5rem, 42%);
    height: auto;
    filter:
      drop-shadow(0 0 1.5rem rgb(224 255 79 / 12%))
      drop-shadow(0 1rem 2.25rem rgb(0 0 0 / 28%));
    opacity: 0.98;
    animation: hero-float 8s ease-in-out infinite;
  }

  .hero-orbit {
    position: absolute;
    border: 1px solid rgb(127 221 211 / 18%);
    border-radius: 999px;
  }

  .hero-orbit-large {
    width: 74%;
    aspect-ratio: 1;
    background:
      radial-gradient(circle at 50% 50%, rgb(127 221 211 / 10%), transparent 0 62%);
    animation: orbit-drift 28s linear infinite;
  }

  .hero-orbit-small {
    width: 48%;
    aspect-ratio: 1;
    transform: rotate(24deg);
    border-color: rgb(224 255 79 / 24%);
    animation: orbit-drift-reverse 22s linear infinite;
  }

  .hero-grid-runes {
    position: absolute;
    inset: 2.2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
    opacity: 0.7;
  }

  .hero-grid-runes > span {
    border-radius: 1rem;
    border: 1px solid rgb(75 131 140 / 16%);
    background:
      linear-gradient(180deg, rgb(127 221 211 / 5%), rgb(4 25 30 / 0%)),
      rgb(4 25 30 / 8%);
  }

  .hero-data-lines {
    position: absolute;
    inset-inline: 1.8rem;
    inset-block-end: 1.4rem;
    display: grid;
    gap: 0.55rem;
  }

  .hero-data-lines > span {
    height: 1px;
    background: linear-gradient(90deg, rgb(127 221 211 / 0%), rgb(127 221 211 / 22%), rgb(127 221 211 / 0%));
    transform-origin: center;
  }

  .hero-contact-band {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    align-items: center;
    padding-top: 1.35rem;
    border-top: 1px solid rgb(75 131 140 / 28%);
  }

  .hero-contact-label,
  .panel-header > p,
  .focus-item > span {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-aqua);
  }

  .hero-contact-copy {
    display: grid;
    gap: 0.45rem;
  }

  .hero-contact-title {
    margin: 0;
    max-width: 36rem;
    color: color-mix(in srgb, var(--secondary-foreground) 88%, white 12%);
    font-size: 0.98rem;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .hero-contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .hero-contact-links :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
  }

  .content-panel {
    padding: 1.75rem;
  }

  .panel-header {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .panel-header > h2,
  .panel-heading-copy > h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .panel-heading-copy {
    display: grid;
    gap: 0.75rem;
  }

  .panel-heading-copy > p {
    margin: 0;
    max-width: 54rem;
    color: var(--muted-foreground);
    line-height: 1.7;
  }

  .focus-grid {
    position: relative;
    z-index: 1;
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .focus-item,
  .project-card {
    min-height: 100%;
    border: 1px solid rgb(75 131 140 / 24%);
    border-radius: 1.5rem;
    background: rgb(4 25 30 / 42%);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 3%);
  }

  .focus-item {
    padding: 1.25rem;
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .focus-item > h3 {
    margin: 0;
    max-width: 16ch;
    font-size: 1.2rem;
    line-height: 1.35;
    color: var(--foreground);
  }

  .projects-grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project-card {
    padding: 1.25rem;
    display: grid;
    gap: 0.75rem;
  }

  .project-card > h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--foreground);
  }

  .project-card > p {
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.65;
  }

  .experience-panel :global(.experience) {
    position: relative;
    z-index: 1;
  }

  @keyframes hero-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-0.5rem);
    }
  }

  @keyframes orbit-drift {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes orbit-drift-reverse {
    from {
      transform: rotate(24deg);
    }
    to {
      transform: rotate(-336deg);
    }
  }

  @media (width >= 860px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.34fr) minmax(16rem, 0.66fr);
      align-items: center;
      min-height: min(66dvh, 39rem);
    }

    .hero-contact-band {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      justify-content: space-between;
    }

    .panel-header {
      grid-template-columns: 4rem minmax(0, 1fr);
      align-items: start;
    }
  }

  @media (width <= 859px) {
    .portfolio-page {
      padding-top: 1rem;
    }
  }

  @media (width <= 720px) {
    .portfolio-page {
      width: min(100%, calc(100% - 1rem));
      gap: 1rem;
    }

    .hero-panel,
    .content-panel {
      border-radius: 1.5rem;
    }

    .hero-panel,
    .content-panel {
      padding: 1.25rem;
    }

    .focus-grid,
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .hero-kicker,
    .hero-contact-label,
    .panel-header > p,
    .focus-item > span {
      letter-spacing: 0.12em;
    }

    .hero-copy > h1 {
      max-width: 100%;
      font-size: clamp(2.7rem, 15vw, 4rem);
      text-wrap: balance;
    }

    .hero-visual {
      min-height: 16rem;
    }

    .hero-brand-mark {
      width: min(9rem, 40%);
    }

    .hero-grid-runes {
      inset: 1.4rem;
      gap: 0.5rem;
    }

    .hero-contact-title {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-brand-mark,
    .hero-orbit-large,
    .hero-orbit-small {
      animation: none;
    }
  }
</style>
