---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';

import Badge from '../components/Badge.astro';
import ExperienceContainer from '../components/Experience.astro';
import HeroActions from '../components/HeroActions';
import SocialPill from '../components/SocialPill.astro';
import SectionContainer from '../components/SectionContainer.astro';
import GitHubIcon from '../icons/GitHubIcon.astro';
import LinkedInIcon from '../icons/LinkedInIcon.astro';
import MailIcon from '../icons/MailIcon.astro';
import {
  getAlternateLocale,
  getHomeCopy,
  localizeExperiences,
  locales,
  type Locale,
} from '../i18n/site';
import Layout from '../layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = getHomeCopy(locale);
const entries = await getCollection('experiences');
const experiences = localizeExperiences(entries, locale);
const alternateLocale = getAlternateLocale(locale);
const canonicalPath = getRelativeLocaleUrl(locale, '');
const alternatePath = getRelativeLocaleUrl(alternateLocale, '');
const navigation = copy.navigation.map((item) => ({
  label: item.label,
  href: `${getRelativeLocaleUrl(locale, '')}${item.hash}`,
}));
const alternates = locales.map((localeCode) => ({
  hreflang: localeCode,
  href: getRelativeLocaleUrl(localeCode, ''),
}));
---

<Layout
  title={copy.title}
  description={copy.description}
  lang={locale}
  canonicalPath={canonicalPath}
  alternates={[
    ...alternates,
    { hreflang: 'x-default', href: getRelativeLocaleUrl('es', '') },
  ]}
  navigation={navigation}
  languageSwitcherLabel={copy.languageSwitcherLabel}
  languageLabel={copy.languageLabel}
  languageSwitcherHref={alternatePath}
  languageSwitcherLocale={alternateLocale}
  logoAlt={copy.logoAlt}
>
  <main id="top">
    <SectionContainer class:list={['section-main']}>
      <h1>
        {copy.greeting}
        <a href="http://linkedin.com/in/smaje" target="_blank" rel="noopener noreferrer">
          <Badge>{copy.availability}</Badge>
        </a>
      </h1>
      <h2>
        {copy.heroFacts.map((fact) => <span>{fact}</span>)}
      </h2>

      <HeroActions
        talkLabel={copy.heroActions.talk}
        githubLabel={copy.heroActions.github}
      />

      <nav id="contact" aria-label={copy.socials.contact}>
        <SocialPill href="http://linkedin.com/in/smaje">
          <LinkedInIcon />
          {copy.socials.linkedin}
        </SocialPill>
        <SocialPill href="https://github.com/smaje99">
          <GitHubIcon />
          {copy.socials.github}
        </SocialPill>
        <SocialPill href="mailto:smajefranco@gmail.com">
          <MailIcon />
          {copy.socials.contact}
        </SocialPill>
      </nav>
    </SectionContainer>

    <SectionContainer>
      <section id="experience" class="experience-section" aria-labelledby="experience-title">
        <header class="section-heading">
          <p>{copy.experienceSection.intro}</p>
          <h2 id="experience-title">{copy.experienceSection.title}</h2>
        </header>
        <ExperienceContainer
          experiences={experiences}
          locale={locale}
          labels={copy.experienceLabels}
        />
      </section>
    </SectionContainer>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 8rem 1rem 1rem 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    font-size: 20px;
    line-height: 1.6;
  }

  h1 {
    display: inline-flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
    padding-bottom: 2.5rem;
    font-size: 3rem;
    line-height: 1;
    font-weight: 700;
    color: var(--foreground);

    & > a {
      width: fit-content;
      display: inline-flex;
    }
  }

  h2 {
    font-size: 1.5rem;
    line-height: 2rem;
    text-wrap: wrap;
    color: var(--muted-foreground);

    & > span {
      &:nth-child(2) {
        color: var(--brand-lime);
        font-weight: 600;
      }

      &:nth-child(3) {
        color: var(--brand-aqua);
        font-weight: 600;
      }

      &:last-child {
        color: var(--secondary-foreground);
      }
    }
  }

  nav {
    max-width: fit-content;
    display: flex;
    flex-wrap: wrap;
    column-gap: 1rem;
    row-gap: 1rem;
    margin-top: 2rem;

    & > a {
      & > svg {
        width: 1.5rem;
        height: 1.5rem;
      }

      &:not(:first-child) > svg {
        color: var(--foreground);
      }
    }
  }

  .section-main {
    min-height: calc(100dvh - 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .experience-section {
    padding-bottom: 4rem;
  }

  .section-heading {
    margin-bottom: 2rem;

    & > p {
      max-width: 56ch;
      margin: 0 0 0.75rem;
      color: var(--muted-foreground);
      font-size: 1rem;
    }

    & > h2 {
      margin: 0;
      color: var(--foreground);
      font-size: 2rem;
      line-height: 1.1;
    }
  }

  @media (width <= 720px) {
    main {
      padding-top: 2rem;
      font-size: 18px;
    }

    h1 {
      font-size: 2.3rem;
    }

    h2 {
      font-size: 1.2rem;
      line-height: 1.75rem;
    }

    .section-heading > h2 {
      font-size: 1.75rem;
    }
  }
</style>
