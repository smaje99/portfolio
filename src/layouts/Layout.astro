---
import "@fontsource-variable/onest";
import "normalize.css";
import "@/styles/global.css";

import Header from "@/components/Header.astro";
import type { Locale } from "@/i18n/site";

interface Props {
  title: string;
  description: string;
  lang: Locale;
  canonicalPath: string;
  alternates: { hreflang: string; href: string }[];
  navigation: { label: string; href: string }[];
  languageSwitcherLabel: string;
  languageLabel: string;
  languageSwitcherHref: string;
  languageSwitcherLocale: Locale;
  logoAlt: string;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  alternates,
  navigation,
  languageSwitcherLabel,
  languageLabel,
  languageSwitcherHref,
  languageSwitcherLocale,
  logoAlt,
} = Astro.props;

const resolveHref = (href: string) => {
  if (!Astro.site) return href;
  return new URL(href, Astro.site).toString();
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={resolveHref(canonicalPath)} />
    {alternates.map((alternate) => (
      <link
        rel="alternate"
        hreflang={alternate.hreflang}
        href={resolveHref(alternate.href)}
      />
    ))}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang === 'es' ? 'es_CO' : 'en_US'} />
    <meta property="og:url" content={resolveHref(canonicalPath)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="layout-background"></div>

    <Header
      navigation={navigation}
      languageSwitcherLabel={languageSwitcherLabel}
      languageLabel={languageLabel}
      languageSwitcherHref={languageSwitcherHref}
      languageSwitcherLocale={languageSwitcherLocale}
      logoAlt={logoAlt}
    />
    <slot />
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
  }

  .layout-background {
    position: fixed;
    inset: 0;
    top: 0;
    z-index: -2;

    width: 100vw;
    height: 100dvh;

    background:
      radial-gradient(circle at 18% 14%, rgb(224 255 79 / 18%), transparent 0 24rem),
      radial-gradient(circle at 82% 6%, rgb(127 221 211 / 15%), transparent 0 22rem),
      linear-gradient(180deg, rgb(7 34 40 / 94%), rgb(4 25 30 / 100%));
    isolation: isolate;
  }

  .layout-background::before,
  .layout-background::after {
    content: "";
    position: absolute;
    inset: 0;
  }

  .layout-background::before {
    background-image:
      linear-gradient(var(--brand-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--brand-grid) 1px, transparent 1px);
    background-size: 4.5rem 4.5rem;
    mask-image: linear-gradient(180deg, rgb(0 0 0 / 65%), transparent 88%);
  }

  .layout-background::after {
    background:
      linear-gradient(135deg, rgb(224 255 79 / 0%) 24%, rgb(224 255 79 / 6%) 52%, rgb(224 255 79 / 0%) 74%);
    opacity: 0.85;
    mix-blend-mode: screen;
  }
</style>
